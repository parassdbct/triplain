{
  "xsappname"  : "trip-app",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://0d164e94trial-dev-trip-app-approuter.cfapps.us10-001.hana.ondemand.com/**"
    ]
  },
  "scopes": [
    {
      "name"       : "$XSAPPNAME.User",
      "description": "Use the Trip App"
    }
  ],
  "role-templates": [
    {
      "name"            : "User",
      "description"     : "Trip App User",
      "scope-references": ["$XSAPPNAME.User"]
    }
  ],
  "role-collections": [
    {
      "name"                    : "TripApp User",
      "role-template-references": ["$XSAPPNAME.User"]
    }
  ]
}